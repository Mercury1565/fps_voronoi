# FPS sample count (M), used by every demo.
SAMPLES=64

# 2 = top-down 2-D view, 3 = full 3-D.
DIMS=3

# Optional legacy cylinder crop, OFF by default (the ROI box below is the default
# crop). Uncomment to re-enable the horizontal radius (m) and/or ground floor (m).
# Note: if set, these intersect with the ROI box — the stricter bound wins.
# MAX_RANGE=40
# MIN_Z=-1.5

# Max edits per frame before a full FPS rebuild. Scale this up with SAMPLES:
# at M=64 ~40 is fine; at M=1024 it must be in the hundreds or the loop just
# rebuilds from scratch every frame.
BUDGET=40

# Region-of-interest box crop (x,y,z), in metres. When both are set, only points
# inside [ROI_MIN, ROI_MAX] are kept — a stricter, z-bounded alternative to the
# MAX_RANGE cylinder that stabilises FPS. Leave unset to disable.
ROI_MIN=-50,-50,-3
ROI_MAX=50,50,3

# Ego-vehicle removal: half-extents (x,y,z) of a box at the sensor origin; points
# inside it (the vehicle's own returns) are dropped. Leave unset to disable.
EGO_EXTENT=0.75,1.5,1
